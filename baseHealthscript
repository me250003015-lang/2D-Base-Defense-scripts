using UnityEngine;
using UnityEngine.UI;
using TMPro;

public class baseHealth : MonoBehaviour
{
    public float health = 100;
    public float maxhealth = 100;
    public GameObject gameOverText;
    public enemyspawnerscript enemyspawnerscript1;
    public enemyspawnerscript enemyspawnerscript2;
    public enemyspawnerscript enemyspawnerscript3;
    public Sprite[] baseSprites;
    public SpriteRenderer baseSr;
    //public TextMeshProUGUI finalScoreText;
    public TextMeshProUGUI healthText;
    
    // Start is called once before the first execution of Update after the MonoBehaviour is created
    void Start()
    {
        health = maxhealth;
        UpdateHealthText();
        gameOverText.SetActive(false);
    }
    public void TakeDamage(int damage)
    {
        health -= damage;
        health = Mathf.Max(0, health);
        UpdateHealthText();
        if (health <= 0)
        {
            //health = 0;
            Debug.Log("Game Over");
        }
    }
    //void Update()
    //{
    
    //}
    
    // Update is called once per frame
    void Update()
    {
        //UpdateHealthText();
        if (health <= 0)
        {
            gameOverText.SetActive(true);
            enemyspawnerscript1.enabled = false;
            enemyspawnerscript2.enabled = false;
            enemyspawnerscript3.enabled = false;
            //finalScoreText.gameObject.SetActive(true);
            //finalScoreText.text = "Final Score :"+ScoreManager.score;
            //Destroy(enemyspawnerscript1.gameObject);
            GameObject[] enemies =
                GameObject.FindGameObjectsWithTag("enemy");
            foreach (GameObject enemy in enemies)
            {
                Destroy(enemy);
            }

            Time.timeScale = 0f;
            Destroy(gameObject);
            FindFirstObjectByType<GameManager>().GameOver();
        }
        else
        {
            float healthPercentage = (float)health / maxhealth;
            int spriteIndex = Mathf.Clamp(Mathf.FloorToInt(healthPercentage * baseSprites.Length - 1), 0, baseSprites.Length - 1);
            baseSr.sprite = baseSprites[spriteIndex];
        }
    }
    void UpdateHealthText()
    { float healthpercent=((float)health)/maxhealth*100f;
        healthText.text = "Base Health: " + Mathf.RoundToInt(healthpercent) + "%";
    }
}
